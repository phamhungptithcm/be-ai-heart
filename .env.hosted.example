BE_AI_HEART_API_BASE_URL=https://api.beheart.dev
BE_AI_HEART_WEBSITE_BASE_URL=https://beheart.dev
BE_AI_HEART_PORTAL_BASE_URL=https://portal.beheart.dev
BE_AI_HEART_ADMIN_BASE_URL=https://admin.beheart.dev

NEXT_PUBLIC_BE_AI_HEART_API_BASE_URL=https://api.beheart.dev
NEXT_PUBLIC_BE_AI_HEART_WEBSITE_BASE_URL=https://beheart.dev
NEXT_PUBLIC_BE_AI_HEART_PORTAL_BASE_URL=https://portal.beheart.dev
NEXT_PUBLIC_BE_AI_HEART_ADMIN_BASE_URL=https://admin.beheart.dev

BE_AI_HEART_SERVICE_STORAGE_BACKEND=postgres
BE_AI_HEART_POSTGRES_URL=postgres://user:password@host:5432/beheart

BE_AI_HEART_AUTH0_ISSUER=https://tenant.us.auth0.com
BE_AI_HEART_AUTH0_CLIENT_ID=replace-with-auth0-client-id
BE_AI_HEART_AUTH0_CLIENT_SECRET=replace-with-auth0-client-secret
BE_AI_HEART_AUTH0_AUDIENCE=replace-with-auth0-api-audience
BE_AI_HEART_AUTH0_SCOPE=openid profile email
BE_AI_HEART_AUTH0_ACTOR_CLAIM=email
BE_AI_HEART_AUTH0_CUSTOMER_CLAIM=be_ai_heart_customer_slug
BE_AI_HEART_AUTH0_WORKSPACE_CLAIM=be_ai_heart_workspaces
BE_AI_HEART_AUTH0_ROLE_CLAIM=roles
BE_AI_HEART_AUTH0_EMAIL_CLAIM=email

BE_AI_HEART_CLERK_OIDC_ISSUER=https://clerk.example.com/oauth
BE_AI_HEART_CLERK_CLIENT_ID=replace-with-clerk-client-id
BE_AI_HEART_CLERK_CLIENT_SECRET=replace-with-clerk-client-secret
BE_AI_HEART_CLERK_AUDIENCE=replace-with-clerk-audience
BE_AI_HEART_CLERK_SCOPE=openid profile email
BE_AI_HEART_CLERK_ACTOR_CLAIM=email
BE_AI_HEART_CLERK_CUSTOMER_CLAIM=be_ai_heart_customer_slug
BE_AI_HEART_CLERK_WORKSPACE_CLAIM=be_ai_heart_workspaces
BE_AI_HEART_CLERK_ROLE_CLAIM=roles
BE_AI_HEART_CLERK_EMAIL_CLAIM=email
