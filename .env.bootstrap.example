# Copy this file to .env.bootstrap.local, fill in your real values,
# then run:
#
#   set -a
#   source ./.env.bootstrap.local
#   set +a
#   DRY_RUN=1 ./scripts/bootstrap-github-gcp.sh
#
# Remove DRY_RUN=1 after you confirm the commands look correct.

# Required
OWNER=your-github-owner
REPO=be-ai-heart
PROJECT_ID=your-gcp-project-id

# Optional overrides
# PROJECT_NUMBER=
REGION=us-central1

FIREBASE_PROJECT_ID=beheart-df3dd
FIREBASE_BACKEND_WEBSITE=beheart-website
FIREBASE_BACKEND_PORTAL=beheart-portal
FIREBASE_BACKEND_ADMIN=beheart-admin

ARTIFACT_REGISTRY_REPOSITORY=beheart
CLOUD_RUN_SERVICE_API=beheart-api

SERVICE_ACCOUNT_ID=be-ai-heart-github
WIF_POOL_ID=github-pool
WIF_PROVIDER_ID=github-provider

# Optional toggles
DRY_RUN=1
CREATE_FIREBASE_BACKENDS=0
