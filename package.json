{
  "name": "be-ai-heart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "test": "node --test",
    "check": "npm run build && npm run test",
    "overview": "node ./packages/cli/bin/heart.js overview --json",
    "mcp:tools": "node ./packages/cli/bin/heart.js mcp tools --json",
    "mcp:serve": "node ./packages/cli/bin/heart.js mcp serve"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
